# ── Serveur Solver Pro PokerForge ──
# Port d'écoute (défaut 8787)
SOLVER_PORT=8787

# Clé API qui protège le endpoint /solve (génère une chaîne longue et secrète).
# Doit être IDENTIQUE à la valeur du secret SOLVER_API_KEY côté Supabase.
# Exemple : openssl rand -hex 32
SOLVER_API_KEY=change-me-pour-une-cle-secrete-longue

# ──────────────────────────────────────────────────────────────────────
# CÔTÉ POKERFORGE (Supabase) — à renseigner dans :
#   Dashboard Supabase → Edge Functions → solver-analyze → Secrets
#
#   SOLVER_API_URL  = https://TON-DOMAINE/solve     (l'URL publique de CE serveur)
#   SOLVER_API_KEY  = (la même clé que ci-dessus)
#
# Tant que SOLVER_API_URL n'est pas défini côté Supabase, PokerForge utilise
# son moteur heuristique local (badge « moteur local » / « ANALYSE ESTIMÉE »).
# Une fois renseigné → engine:"pro", estimated:false, équité réelle.
# ──────────────────────────────────────────────────────────────────────
