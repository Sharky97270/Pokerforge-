# PokerForge — Variables d'environnement
# Copier ce fichier en .env.local pour le dev local.
# Dans Vercel, créer ces variables dans Project → Settings → Environment Variables.

# Supabase → Settings → API → Project URL
VITE_SUPABASE_URL="https://[project-ref].supabase.co"

# Supabase → Settings → API → anon / public key
# Cette clé est publique côté frontend ; les secrets restent côté Supabase Edge Functions.
VITE_SUPABASE_ANON_KEY="eyJ..."

# Environnement applicatif affichable côté frontend
VITE_APP_ENV="preview"

# Prisma / scripts serveur locaux uniquement, ne pas exposer au frontend.
# Supabase → Settings → Database → Connection string → URI (Transaction Pooler)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase → Settings → Database → Connection string → URI (Session Pooler ou Direct)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# Secrets côté Supabase Edge Functions, pas côté Vercel frontend.
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
